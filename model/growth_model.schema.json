{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fundraiseup.local/schemas/cause-cure-growth-model.schema.json",
  "title": "Cause&Cure Growth Model",
  "description": "Schema for Cause&Cure GPV growth model inputs, anchors, assumptions and derived targets.",
  "type": "object",
  "required": [
    "metadata",
    "verticals",
    "market",
    "targets",
    "historical",
    "segmentation",
    "assumptions"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title", "currency", "unit", "generated_at", "source_files"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "currency": { "type": "string", "const": "USD" },
        "unit": { "type": "string", "enum": ["M"] },
        "generated_at": { "type": "string", "format": "date-time" },
        "source_files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "verticals": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "market": {
      "type": "object",
      "required": ["personal_giving"],
      "properties": {
        "personal_giving": {
          "$ref": "#/$defs/personalGivingMarket"
        }
      },
      "additionalProperties": false
    },
    "targets": {
      "type": "object",
      "required": ["cc_gpv_m", "take_rate"],
      "properties": {
        "cc_gpv_m": {
          "type": "object",
          "required": ["2024", "2025", "2026", "2027", "2028"],
          "properties": {
            "2024": { "type": "number", "minimum": 0 },
            "2025": { "type": "number", "minimum": 0 },
            "2026": { "type": "number", "minimum": 0 },
            "2027": { "type": "number", "minimum": 0 },
            "2028": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "take_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "historical": {
      "type": "object",
      "required": ["all_gpv", "faith_gpv", "cc_gpv", "cohort_anchor_2025", "cc_one_time_recurring"],
      "properties": {
        "all_gpv": { "$ref": "#/$defs/yearPair" },
        "faith_gpv": { "$ref": "#/$defs/yearPair" },
        "cc_gpv": { "$ref": "#/$defs/yearPair" },
        "cohort_anchor_2025": {
          "type": "object",
          "required": [
            "legacy_contribution",
            "new_2025_contribution",
            "legacy_one_time",
            "legacy_recurring",
            "new_one_time",
            "new_recurring"
          ],
          "properties": {
            "legacy_contribution": { "type": "number", "minimum": 0 },
            "new_2025_contribution": { "type": "number", "minimum": 0 },
            "legacy_one_time": { "type": "number", "minimum": 0 },
            "legacy_recurring": { "type": "number", "minimum": 0 },
            "new_one_time": { "type": "number", "minimum": 0 },
            "new_recurring": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "cc_one_time_recurring": {
          "type": "object",
          "required": ["2024", "2025"],
          "properties": {
            "2024": { "$ref": "#/$defs/otRec" },
            "2025": { "$ref": "#/$defs/otRec" }
          },
          "additionalProperties": false
        },
        "legacy_observed_kpis": {
          "type": "object",
          "required": [
            "nrr_2024_to_2025",
            "carryover_component_ratio",
            "implied_existing_account_expansion_rate"
          ],
          "properties": {
            "nrr_2024_to_2025": { "type": "number", "minimum": 0 },
            "carryover_component_ratio": { "type": "number", "minimum": 0 },
            "implied_existing_account_expansion_rate": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "segmentation": {
      "type": "object",
      "required": [
        "taxonomy",
        "coverage_2024_known_accounts",
        "analytical_brackets",
        "cc_2025_distribution",
        "cc_2025_new_accounts_distribution"
      ],
      "properties": {
        "taxonomy": {
          "type": "object",
          "required": ["primary", "secondary"],
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          },
          "additionalProperties": false
        },
        "coverage_2024_known_accounts": {
          "type": "object",
          "required": [
            "total_2024_accounts",
            "covered_total",
            "coverage_pct",
            "ntee_coverage_pct",
            "fru_sector_coverage_pct",
            "fru_subsector_coverage_pct"
          ],
          "properties": {
            "total_2024_accounts": { "type": "integer", "minimum": 0 },
            "covered_total": { "type": "integer", "minimum": 0 },
            "coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
            "ntee_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
            "fru_sector_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
            "fru_subsector_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        },
        "analytical_brackets": {
          "type": "array",
          "items": { "$ref": "#/$defs/bracket" },
          "minItems": 1
        },
        "cc_2025_distribution": {
          "type": "array",
          "items": { "$ref": "#/$defs/bracketDistribution" },
          "minItems": 1
        },
        "cc_2025_new_accounts_distribution": {
          "type": "array",
          "items": { "$ref": "#/$defs/bracketNewDistribution" },
          "minItems": 1
        },
        "by_vertical": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "object",
      "required": [
        "recurring_donor_lifetime_months",
        "annual_recurring_carryover",
        "new_donor_year1_split",
        "one_time_donor_year2_repeat_rate",
        "existing_account_expansion_rate",
        "cohort_year1_nrr",
        "cohort_year2plus_nrr",
        "cohort_year2_nrr",
        "new_account_year1_to_year2_gpv_ratio",
        "lt_100k_year1_gpv_per_logo_override_m",
        "max_new_whales_per_year",
        "bracket_mix_shift_2026_2028"
      ],
      "properties": {
        "recurring_donor_lifetime_months": { "type": "number", "minimum": 1 },
        "annual_recurring_carryover": { "type": "number", "minimum": 0, "maximum": 1 },
        "new_donor_year1_split": {
          "type": "object",
          "required": ["one_time", "recurring"],
          "properties": {
            "one_time": { "type": "number", "minimum": 0, "maximum": 1 },
            "recurring": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "one_time_donor_year2_repeat_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "existing_account_expansion_rate": { "type": "number", "minimum": 0 },
        "cohort_year1_nrr": { "type": "number", "minimum": 0.01 },
        "cohort_year2plus_nrr": { "type": "number", "minimum": 0.01 },
        "cohort_year2_nrr": { "type": "number", "minimum": 0.01 },
        "new_account_year1_to_year2_gpv_ratio": { "type": "number", "minimum": 0.01, "maximum": 1 },
        "lt_100k_year1_gpv_per_logo_override_m": { "type": "number", "minimum": 0 },
        "max_new_whales_per_year": { "type": "integer", "minimum": 0 },
        "bracket_mix_shift_2026_2028": { "type": "string" }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "yearPair": {
      "type": "object",
      "required": ["2024", "2025"],
      "properties": {
        "2024": { "type": "number", "minimum": 0 },
        "2025": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "otRec": {
      "type": "object",
      "required": ["one_time", "recurring", "recurring_share"],
      "properties": {
        "one_time": { "type": "number", "minimum": 0 },
        "recurring": { "type": "number", "minimum": 0 },
        "recurring_share": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "bracket": {
      "type": "object",
      "required": ["id", "label", "min"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "bracketDistribution": {
      "type": "object",
      "required": ["id", "label", "account_count", "gpv_total", "share_of_accounts", "share_of_gpv"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "account_count": { "type": "integer", "minimum": 0 },
        "gpv_total": { "type": "number", "minimum": 0 },
        "share_of_accounts": { "type": "number", "minimum": 0, "maximum": 100 },
        "share_of_gpv": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "bracketNewDistribution": {
      "allOf": [
        { "$ref": "#/$defs/bracketDistribution" },
        {
          "type": "object",
          "required": ["avg_year1_gpv", "median_year1_gpv"],
          "properties": {
            "avg_year1_gpv": { "type": "number", "minimum": 0 },
            "median_year1_gpv": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      ]
    },
    "personalGivingMarket": {
      "type": "object",
      "required": [
        "name",
        "currency",
        "assumed_nominal_growth_rate",
        "projection_method",
        "split_method",
        "surface_split_method",
        "channel_split_method",
        "sources",
        "years",
        "segments",
        "surfaces",
        "channels"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "currency": { "type": "string", "const": "USD" },
        "assumed_nominal_growth_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "projection_method": { "type": "string", "minLength": 1 },
        "split_method": { "type": "string", "minLength": 1 },
        "surface_split_method": { "type": "string", "minLength": 1 },
        "channel_split_method": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/marketSource" }
        },
        "years": {
          "type": "object",
          "required": ["2024", "2025", "2026", "2027", "2028"],
          "properties": {
            "2024": { "$ref": "#/$defs/marketYear" },
            "2025": { "$ref": "#/$defs/marketYear" },
            "2026": { "$ref": "#/$defs/marketYear" },
            "2027": { "$ref": "#/$defs/marketYear" },
            "2028": { "$ref": "#/$defs/marketYear" }
          },
          "additionalProperties": false
        },
        "segments": {
          "type": "object",
          "required": ["faith", "cc"],
          "properties": {
            "faith": { "$ref": "#/$defs/marketSegment" },
            "cc": { "$ref": "#/$defs/marketSegment" }
          },
          "additionalProperties": false
        },
        "surfaces": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/marketSurface" }
        },
        "channels": {
          "type": "object",
          "required": ["online", "offline"],
          "properties": {
            "online": { "$ref": "#/$defs/marketChannel" },
            "offline": { "$ref": "#/$defs/marketChannel" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "marketSource": {
      "type": "object",
      "required": ["name", "url"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "published_at": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "marketYear": {
      "type": "object",
      "required": ["state", "market_size_usd", "is_actual"],
      "properties": {
        "state": { "type": "string", "enum": ["past", "present", "future"] },
        "market_size_usd": { "type": "number", "minimum": 0 },
        "is_actual": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "marketSegment": {
      "type": "object",
      "required": ["name", "years"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "years": {
          "type": "object",
          "required": ["2024", "2025", "2026", "2027", "2028"],
          "properties": {
            "2024": { "$ref": "#/$defs/marketSegmentYear" },
            "2025": { "$ref": "#/$defs/marketSegmentYear" },
            "2026": { "$ref": "#/$defs/marketSegmentYear" },
            "2027": { "$ref": "#/$defs/marketSegmentYear" },
            "2028": { "$ref": "#/$defs/marketSegmentYear" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "marketSegmentYear": {
      "type": "object",
      "required": ["share_of_total", "market_size_usd"],
      "properties": {
        "share_of_total": { "type": "number", "minimum": 0, "maximum": 1 },
        "market_size_usd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "marketSurface": {
      "type": "object",
      "required": ["name", "years"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "years": {
          "type": "object",
          "required": ["2024", "2025", "2026", "2027", "2028"],
          "properties": {
            "2024": { "$ref": "#/$defs/marketSurfaceYear" },
            "2025": { "$ref": "#/$defs/marketSurfaceYear" },
            "2026": { "$ref": "#/$defs/marketSurfaceYear" },
            "2027": { "$ref": "#/$defs/marketSurfaceYear" },
            "2028": { "$ref": "#/$defs/marketSurfaceYear" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "marketSurfaceYear": {
      "type": "object",
      "required": ["share_of_total", "market_size_usd", "is_observed"],
      "properties": {
        "share_of_total": { "type": "number", "minimum": 0, "maximum": 1 },
        "market_size_usd": { "type": "number", "minimum": 0 },
        "is_observed": { "type": "boolean" },
        "observed_volume_usd": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "marketChannel": {
      "type": "object",
      "required": ["name", "years"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "years": {
          "type": "object",
          "required": ["2024", "2025", "2026", "2027", "2028"],
          "properties": {
            "2024": { "$ref": "#/$defs/marketChannelYear" },
            "2025": { "$ref": "#/$defs/marketChannelYear" },
            "2026": { "$ref": "#/$defs/marketChannelYear" },
            "2027": { "$ref": "#/$defs/marketChannelYear" },
            "2028": { "$ref": "#/$defs/marketChannelYear" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "marketChannelYear": {
      "type": "object",
      "required": ["share_of_total", "market_size_usd", "evidence"],
      "properties": {
        "share_of_total": { "type": "number", "minimum": 0, "maximum": 1 },
        "market_size_usd": { "type": "number", "minimum": 0 },
        "evidence": { "type": "string", "enum": ["observed", "inferred", "projected"] }
      },
      "additionalProperties": false
    }
  }
}
